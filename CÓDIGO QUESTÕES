T = 1                  # Tempo (s)

t = np.arange(0, T, 1/fs)

# =====================================
# Sinal composto
# =====================================

f1 = 50
f2 = 150
f3 = 300

x = (np.sin(2*np.pi*f1*t) +
     np.sin(2*np.pi*f2*t) +
     np.sin(2*np.pi*f3*t))

# =====================================
# Projeto do filtro passa-faixa
# =====================================

f_low = 130
f_high = 170

