import numpy as np
import matplotlib.pyplot as plt
from scipy.signal import butter, tf2zpk

# ======================================
# Projeto do filtro Butterworth
# ======================================

fs = 1000          # Frequência de amostragem (Hz)
fc = 100           # Frequência de corte (Hz)
ordem = 4

# Coeficientes do filtro

b, a = butter(ordem,
              fc/(fs/2),
              btype='low')

# ======================================
# Polos e Zeros
# ======================================

zeros, polos, ganho = tf2zpk(b, a)

# ======================================
# Círculo Unitário
# ======================================

theta = np.linspace(0, 2*np.pi, 500)

x = np.cos(theta)
y = np.sin(theta)

# ======================================
# Gráfico
# ======================================

plt.figure(figsize=(7,7))

# Círculo unitário
plt.plot(x, y, '--', label='Círculo Unitário')

# Zeros
plt.scatter(np.real(zeros),
            np.imag(zeros),
            marker='o',
            s=100,
            label='Zeros')

# Polos
plt.scatter(np.real(polos),
            np.imag(polos),
            marker='x',
            s=100,
            label='Polos')

plt.axhline(0,color='black')
plt.axvline(0,color='black')

plt.xlabel('Parte Real')

plt.ylabel('Parte Imaginária')

plt.title('Polos e Zeros do Filtro IIR Butterworth')

plt.grid(True)

plt.axis('equal')

plt.legend()

plt.show()

