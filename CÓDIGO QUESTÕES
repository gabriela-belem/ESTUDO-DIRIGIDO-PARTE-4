b, a = butter(ordem,
              [f_low/(fs/2), f_high/(fs/2)],
              btype='bandpass')

# =====================================
# Aplicação do filtro
# =====================================

y = filtfilt(b, a, x)

# =====================================
# FFT
# =====================================

N = len(x)

freq = np.fft.fftfreq(N, 1/fs)

X = np.abs(np.fft.fft(x))
Y = np.abs(np.fft.fft(y))

idx = freq >= 0

# =====================================
# Gráficos
# =====================================

plt.figure(figsize=(12,8))

