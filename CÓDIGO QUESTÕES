import numpy as np
import matplotlib.pyplot as plt
from scipy.signal import butter, filtfilt

# ======================================
# Parâmetros
# ======================================

fs = 100             # Frequência de amostragem (Hz)
T = 20               # Tempo de aquisição (s)

t = np.arange(0, T, 1/fs)

# ======================================
# Simulação da temperatura
# ======================================

temperatura = 25 + 2*np.sin(2*np.pi*0.2*t)

# Ruído branco

np.random.seed(10)

ruido = 0.8*np.random.randn(len(t))

sensor = temperatura + ruido

# ======================================
# Projeto do filtro Butterworth
# ======================================

fc = 2               # Frequência de corte (Hz)

ordem = 4

b, a = butter(ordem,
              fc/(fs/2),
              btype='low')

# Filtragem

sensor_filtrado = filtfilt(b, a, sensor)

# ======================================
# FFT
# ======================================

freq = np.fft.fftfreq(len(sensor),1/fs)

S1 = np.abs(np.fft.fft(sensor))
S2 = np.abs(np.fft.fft(sensor_filtrado))

idx = freq >= 0

# ======================================
# Gráficos
# ======================================

plt.figure(figsize=(12,8))

plt.subplot(2,2,1)
plt.plot(t, sensor)
plt.title("Leitura do Sensor com Ruído")
plt.xlabel("Tempo (s)")
plt.ylabel("Temperatura (°C)")
plt.grid()

plt.subplot(2,2,2)
plt.plot(t, sensor_filtrado)
plt.title("Leitura Após Filtragem")
plt.xlabel("Tempo (s)")
plt.ylabel("Temperatura (°C)")
plt.grid()

plt.subplot(2,2,3)
plt.plot(freq[idx], S1[idx])
plt.title("Espectro Antes da Filtragem")
plt.xlabel("Frequência (Hz)")
plt.ylabel("Magnitude")
plt.grid()

plt.subplot(2,2,4)
plt.plot(freq[idx], S2[idx])
plt.title("Espectro Após Filtragem")
plt.xlabel("Frequência (Hz)")
plt.ylabel("Magnitude")
plt.grid()

plt.tight_layout()

plt.show()

